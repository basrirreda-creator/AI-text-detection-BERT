"""
Inférence et prédictions
"""

import torch
import logging
from transformers import BertTokenizer
from model import BertTextDetector
import numpy as np

logging.basicConfig(level=logging.INFO)
logger = logging.getLogger(__name__)

class TextDetector:
    """Détecteur de textes générés par IA"""
    
    LABELS = {
        0: "Human",
        1: "GPT-3.5",
        2: "GPT-4",
        3: "Claude",
        4: "Gemini"
    }
    
    def __init__(self, model_path: str, device: str = None):
        self.device = device or ("cuda" if torch.cuda.is_available() else "cpu")
        
        # Charger le modèle
        self.model = BertTextDetector(num_classes=5)
        self.model.load_state_dict(torch.load(model_path, map_location=self.device))
        self.model = self.model.to(self.device)
        self.model.eval()
        
        # Tokenizer
        self.tokenizer = BertTokenizer.from_pretrained("bert-base-uncased")
        
        logger.info(f"✅ Modèle chargé sur {self.device}")
    
    def predict(self, text: str) -> dict:
        """Prédire si un texte est généré par IA"""
        
        # Tokenize
        encoding = self.tokenizer(
            text,
            add_special_tokens=True,
            max_length=512,
            return_token_type_ids=True,
            pad_to_max_length=True,
            return_attention_mask=True,
            return_tensors='pt'
        )
        
        input_ids = encoding['input_ids'].to(self.device)
        attention_mask = encoding['attention_mask'].to(self.device)
        token_type_ids = encoding['token_type_ids'].to(self.device)
        
        # Prédiction
        with torch.no_grad():
            outputs = self.model(input_ids, attention_mask, token_type_ids)
            probabilities = torch.softmax(outputs, dim=1)
            predicted_class = torch.argmax(probabilities, dim=1).item()
        
        prob_dict = {
            self.LABELS[i]: float(probabilities[0][i].item())
            for i in range(5)
        }
        
        return {
            'label': self.LABELS[predicted_class],
            'confidence': float(probabilities[0][predicted_class].item()),
            'probabilities': prob_dict,
            'is_ai_generated': predicted_class != 0
        }


# Utilisation
if __name__ == "__main__":
    detector = TextDetector("models/bert_model.pt")
    
    # Texte test
    test_text = "Artificial intelligence and machine learning are rapidly transforming various industries..."
    
    result = detector.predict(test_text)
    
    logger.info(f"\n📝 Text: {test_text[:100]}...")
    logger.info(f"🤖 Prediction: {result['label']}")
    logger.info(f"📊 Confidence: {result['confidence']:.2%}")
    logger.info(f"📈 Probabilities:\n{result['probabilities']}")
